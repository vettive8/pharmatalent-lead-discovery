# =============================================================================
# PharmaTalent Europe — Lead-Discovery Pipeline
# Copy this file to `.env` and fill in your own free-tier credentials.
# Every value below is read from the environment at runtime — there are NO
# hardcoded keys, URLs, or project IDs anywhere in the code. Swapping these
# values is all that is required to point the pipeline at a different account.
# =============================================================================

# --- Apify: LinkedIn Jobs scraper (actor vIGxjRrHqDTPuE6M4) -------------------
# Sign up: https://apify.com  (Settings -> Integrations -> API tokens)
APIFY_TOKEN=

# --- Prospeo.io: people-search (the DMM provider) -----------------------------
# Sign up: https://prospeo.io  -> API key (X-KEY auth).
# This pipeline uses Prospeo (not the brief's default AI Ark) — see the README
# "People-search provider" section for the rationale.
PROSPEO_API_KEY=

# --- OpenRouter: LLMs for ICP fit-check + hiring-manager validation -----------
# Sign up: https://openrouter.ai  -> Keys. Free signup credits + a small (~$5)
# top-up cover a full run (a real run costs well under $1).
OPENROUTER_API_KEY=
# Optional model overrides — the code already defaults to these (rationale in the
# README). Uncomment only to change them:
#   OPENROUTER_FITCHECK_MODEL=perplexity/sonar        # web-research fit-check (browsing)
#   OPENROUTER_VALIDATION_MODEL=deepseek/deepseek-chat # cheap per-candidate validation

# --- Supabase: persistence (jobs / companies / contacts) ----------------------
# Sign up: https://supabase.com  -> create a project.
#
# REQUIRED: the Postgres connection string. We use psycopg so the schema can be
# created from code (CREATE TABLE IF NOT EXISTS) on a BLANK project — the Supabase
# REST/anon API cannot run DDL, so SUPABASE_URL + service-role key are NOT used.
#
# USE THE SESSION POOLER STRING:  Supabase -> Connect -> Session pooler
#   (host like aws-...pooler.supabase.com:5432). It is IPv4-compatible AND supports
#   the schema's DDL. The Direct connection is IPv6-only (fails on IPv4 networks);
#   the Transaction pooler (port 6543) can't run DDL.  ->  So: Session pooler.
# (TOOLS.md §4 explicitly permits this psycopg path.)
SUPABASE_DB_URL=

# --- Pipeline runtime knobs (all optional — sane defaults in config.py) -------
# Comma-separated EU locations to scrape (English names only). Default = ICP.md list.
# SCRAPE_LOCATIONS=Germany,Switzerland,Netherlands,Belgium,Denmark,Sweden,Ireland,France,United Kingdom,Spain,Italy,Austria,Finland,Norway
# Last-N-days window for the scrape (actor time-range param).
# SCRAPE_TIME_RANGE=7d
# Max jobs to request from Apify in one run.
# SCRAPE_MAX_ITEMS=250
