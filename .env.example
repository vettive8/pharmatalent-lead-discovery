# =============================================================================
# PharmaTalent Europe — Lead-Discovery Pipeline
# Copy this file to `.env` and fill in your own free-tier credentials.
# Every value below is read from the environment at runtime — there are NO
# hardcoded keys, URLs, or project IDs anywhere in the code. Swapping these
# values is all that is required to point the pipeline at a different account.
# =============================================================================

# --- Apify: LinkedIn Jobs scraper (actor vIGxjRrHqDTPuE6M4) -------------------
# Sign up: https://apify.com  (Settings -> Integrations -> API tokens)
APIFY_TOKEN=

# --- AI Ark: people-search (OPTIONAL alternative DMM provider) ----------------
# Sign up: https://ai-ark.com  -> generate an API token (X-TOKEN auth).
# Free tier = 100 credits = 100 people TOTAL. The pipeline caps results at 2
# per call and never re-queries the same (company, title) pair on rerun.
# Leave blank to use Prospeo only (the configured/verified provider for this
# repo). Set it to make AI Ark the primary, with Prospeo as fallback.
AI_ARK_TOKEN=
# Optional overrides if AI Ark's API base/path differ for your account:
# AI_ARK_BASE_URL=https://api.ai-ark.com
# AI_ARK_PEOPLE_SEARCH_PATH=/api/developer-portal/v1/people

# --- Prospeo.io: people-search (fallback DMM provider) ------------------------
# Sign up: https://prospeo.io  -> API key. Used automatically when AI Ark
# returns nothing for a (company, title) pair. Leave blank to disable fallback.
PROSPEO_API_KEY=

# --- OpenRouter: LLMs for ICP fit-check + hiring-manager validation -----------
# Sign up: https://openrouter.ai  -> Keys.
OPENROUTER_API_KEY=
# Model picks (override if you like — defaults are documented in the README):
#   - Web-research fit-check needs a browsing-capable model.
#   - Validation runs once per candidate, so it uses a cheap model.
OPENROUTER_FITCHECK_MODEL=perplexity/sonar
OPENROUTER_VALIDATION_MODEL=deepseek/deepseek-chat

# --- Supabase: persistence (jobs / companies / contacts) ----------------------
# Sign up: https://supabase.com  -> create a project.
#
# REQUIRED: the direct Postgres connection string. We use psycopg so the schema
# can be created from code (CREATE TABLE IF NOT EXISTS) on a BLANK project — the
# PostgREST/anon API cannot run DDL. Get it from:
#   Supabase Dashboard -> Project Settings -> Database -> Connection string -> URI
# (Use the "Session"/direct connection, not the transaction pooler, for DDL.)
SUPABASE_DB_URL=

# Optional: only used if you switch the data layer to supabase-py (not the
# default). Documented for completeness; the default psycopg path ignores these.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# --- Pipeline runtime knobs (all optional — sane defaults in config.py) -------
# Comma-separated EU locations to scrape (English names only). Default = ICP.md list.
# SCRAPE_LOCATIONS=Germany,Switzerland,Netherlands,Belgium,Denmark,Sweden,Ireland,France,United Kingdom,Spain,Italy,Austria,Finland,Norway
# Last-N-days window for the scrape (actor time-range param).
# SCRAPE_TIME_RANGE=7d
# Max jobs to request from Apify in one run.
# SCRAPE_MAX_ITEMS=200
